{
  "name": "@viberave/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VibeRave API — multimodal (voice + text) input → Strudel code generation. Pluggable LLM (any OpenAI-compatible endpoint or Ollama) and STT (whisper / vosk local, or any OpenAI-compatible /audio/transcriptions endpoint, plus DashScope native).",
  "main": "src/index.mjs",
  "scripts": {
    "dev": "node --env-file=../../.env --watch src/index.mjs",
    "start": "node --env-file=../../.env src/index.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@strudel/core": "workspace:*",
    "@strudel/draw": "workspace:*",
    "@strudel/mini": "workspace:*",
    "@strudel/tonal": "workspace:*",
    "@strudel/transpiler": "workspace:*",
    "fastify": "^5.2.1",
    "openai": "^6.34.0",
    "smart-whisper": "^0.8.1",
    "vosk-koffi": "^1.1.1",
    "wavefile": "^11.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
